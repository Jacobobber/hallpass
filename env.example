# Copy to .env and fill in. docker compose reads .env automatically:
#   cp env.example .env

# Your OIDC provider (required). The app verifies every bearer against this
# JWKS; these are not secrets.
HALLPASS_ISSUER=https://your-issuer.example.com/
HALLPASS_AUDIENCE=https://your-api.example.com
HALLPASS_JWKS_URL=https://your-issuer.example.com/.well-known/jwks.json

# The Fernet key for the credential vault. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Keep it SECRET and STABLE -- rotating or losing it makes stored credentials
# unreadable, and a different key per replica corrupts a shared vault.
HALLPASS_VAULT_KEY=replace-with-a-generated-fernet-key
